{
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devPath": "http://localhost:5173",
        "distDir": "../dist",
        "withGlobalTauri": false
    },
    "package": {
        "productName": "super-clip",
        "version": "0.6.0"
    },
    "tauri": {
        "allowlist": {
            "all": false,
            "shell": {
                "all": false,
                "open": true
            },
            "dialog": {
                "all": true
            },
            "globalShortcut": {
                "all": true
            },
            "window": {
                "all": true
            },
            "fs": {
                "all": false,
                "readFile": true,
                "scope": [
                    "$APPDATA/**"
                ]
            },
            "protocol": {
                "asset": true,
                "assetScope": [
                    "$APPDATA/**"
                ]
            }
        },
        "bundle": {
            "active": true,
            "category": "Utility",
            "copyright": "Copyright © 2026",
            "deb": {
                "depends": []
            },
            "externalBin": [],
            "icon": [
                "icons/32x32.png",
                "icons/128x128.png",
                "icons/128x128@2x.png",
                "icons/icon.icns",
                "icons/icon.ico"
            ],
            "identifier": "com.super-clip.dev",
            "longDescription": "A powerful cross-platform clipboard manager that helps you manage your clipboard history efficiently.",
            "macOS": {
                "entitlements": null,
                "exceptionDomain": "",
                "frameworks": [],
                "providerShortName": null,
                "signingIdentity": null
            },
            "resources": [],
            "shortDescription": "Cross-platform clipboard manager",
            "targets": "all",
            "windows": {
                "certificateThumbprint": null,
                "digestAlgorithm": "sha256",
                "timestampUrl": "",
                "wix": {
                    "language": "zh-CN"
                }
            }
        },
        "security": {
            "csp": null
        },
        "updater": {
            "active": false,
            "_comment_": "TO ENABLE AUTO-UPDATES (see docs/UPDATES.md): (1) generate a key pair via `npx @tauri-apps/cli signer generate -w ~/.tauri/super-clip.key`, (2) replace pubkey below, (3) flip active=true, (4) on each release, run `tauri build` then upload the .msi/.exe + .sig + a `latest.json` to the GitHub Release matching `endpoints` below. Until those steps are done, leaving active=false is correct — Tauri will neither download nor verify anything.",
            "endpoints": [
                "https://github.com/huangmang/super-clip/releases/latest/download/latest.json"
            ],
            "dialog": true,
            "pubkey": "REPLACE_WITH_TAURI_SIGNER_OUTPUT_BEFORE_ACTIVATING"
        },
        "windows": [
                {
                    "fullscreen": false,
                    "resizable": true,
                    "title": "Super Clip",
                    "width": 800,
                    "height": 600,
                    "center": true,
                    "visible": true,
                    "decorations": false,
                    "transparent": true
                }
            ],
        "systemTray": {
            "iconPath": "icons/32x32.png",
            "iconAsTemplate": false,
            "menuOnLeftClick": true
        }
    }
}