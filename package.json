{
    "name": "super-clip",
    "private": true,
    "version": "0.6.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "typecheck": "tsc --noEmit",
        "lint:rust": "cd src-tauri && cargo clippy --all-targets -- -D warnings",
        "fmt:rust": "cd src-tauri && cargo fmt",
        "test:rust": "cd src-tauri && cargo test --bin super-clip clipboard_tests -- --test-threads=1"
    },
    "dependencies": {
        "@tauri-apps/api": "^1.5.3",
        "@types/dompurify": "^3.0.5",
        "dompurify": "^3.4.0",
        "lucide-react": "^0.344.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-syntax-highlighter": "^16.1.1",
        "tauri-plugin-autostart-api": "^0.0.1-security"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^1.5.9",
        "@types/react": "^18.2.56",
        "@types/react-dom": "^18.2.19",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.3.3",
        "vite": "^5.1.3"
    }
}
